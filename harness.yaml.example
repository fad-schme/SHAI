# harness.yaml.example — canonical reference configuration.
# All fields shown here are consumed by HarnessConfig.
# Fields not listed here do not exist in the schema.

version: 1
tenant_id: "my-deployment"

# ── Input scanning ────────────────────────────────────────────────────────
scan_input:
  enabled: true
  block_at: high
  scanners:
    - name: regex_pii
    - name: injection_scan

# ── File upload scanning ──────────────────────────────────────────────────
# FileScanner handles MIME, size, PDF JS, EXIF, ZIP, Office macros, and
# runs InjectionScanner on extracted text automatically.
scan_file:
  enabled: false
  block_at: high
  max_size_mb: 50

# ── Tool result scanning (indirect injection) — T6 ───────────────────────
scan_tool_result:
  enabled: false
  block_at: high

# ── Tool call gate ────────────────────────────────────────────────────────
check_tool_call:
  rate_limit:
    enabled: false
    window_seconds: 60
    max_calls_per_window: 60
    max_calls_per_tool: 20
  arg_scanners:
    - name: regex_pii
  scan_args_for_tags:
    - sensitive

# ── Output scanning ───────────────────────────────────────────────────────
scan_output:
  enabled: true
  block_at: high
  scanners:
    - name: regex_pii

# ── Policy ────────────────────────────────────────────────────────────────
policy:
  name: rules
  config:
    rules_path: ./policies/rules.yaml

# ── Audit sinks ───────────────────────────────────────────────────────────
# Optional — defaults to stdout when not specified.
# Available: stdout, file
audit_sinks:
  - name: stdout
  # - name: file
  #   config:
  #     path: ./logs/audit.jsonl

# ── Audit signing — T8 ───────────────────────────────────────────────────
# HMAC-SHA256 signs every audit event. secret:// resolved from env var.
audit_signing:
  enabled: false
  secret: "secret://AUDIT_SIGNING_KEY"
