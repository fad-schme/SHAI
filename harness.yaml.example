# harness.yaml.example — canonical reference configuration.
# Uses only reference adapters (pip install harness).

version: 1
tenant_id: "my-deployment"  # unique name for this harness instance

scan_input:
  enabled: true
  block_at: high
  scanners:
    - name: regex_pii
    - name: basic_injection

scan_output:
  enabled: true
  block_at: high
  scanners:
    - name: regex_pii

scan_file:
  enabled: true
  block_at: high
  max_size_mb: 50
  allowed_extensions: [".pdf", ".docx", ".xlsx", ".txt", ".md", ".csv"]
  scanners:
    - name: file_scanner    # structural + content pass (always included)

check_tool_call:
  arg_scanners:
    - name: regex_pii
  scan_args_for_tags:
    - sensitive

policy:
  name: rules
  config:
    rules_path: ./policies/rules.yaml

audit_sinks:
  - name: stdout

tool_registry:
  name: memory

secrets:
  name: env

tool_sources:
  - name: docs_skill
    transport: skill
    tools:
      - search_docs
      - fetch_doc
    tags:
      - skill
      - read
      - internal

  - name: slack_mcp
    transport: mcp
    url: "https://mcp.slack.com/sse"
    credentials:
      token: "secret://SLACK_MCP_TOKEN"
    tags:
      - external_mcp
      - messaging
      - external_write

agents:
  directory: ./agents

logging:
  level: INFO
  json_format: true
