# harness.yaml.example — canonical reference configuration.
# All fields shown here are consumed by HarnessConfig.
# Fields not listed here do not exist in the schema.

version: 1
tenant_id: "my-deployment"

# ── De-obfuscation (applied before every scan boundary) ───────────────────
# Produces decoded / de-fragmented views of text so pattern scanners cannot be
# bypassed by base64, rot13, hex, url-encoding, unicode homoglyphs, invisible
# characters, or fragmentation. On by default — disabling reopens the bypass.
normalization:
  enabled: true
  decode: true            # base64 / hex / url / rot13 substring decoding
  max_depth: 2            # recursion depth for nested encodings
  entropy_threshold: 3.5  # min entropy for a base64 decode candidate
  max_bytes: 262144       # inputs larger than this are folded but not decoded

# ── Cross-turn threat accumulator ─────────────────────────────────────────
# Detects crescendo attacks: escalation distributed across turns where each
# individual turn stays below per-turn scanner thresholds.
# SQLite-backed — risk scores persist across process restarts.
# Pass conversation_id on AgentContext to scope per-conversation; falls back
# to agent_id when omitted.
session:
  enabled: true           # disabled by default — opt in explicitly
  backend: sqlite
  path: state/sessions.db
  escalation_threshold: 0.70   # risk score at which the session is blocked
  window_size: 10              # sliding window of turns to evaluate
  reframe_similarity: 0.72    # bigram Jaccard threshold for reframe detection
  ttl_hours: 72               # session state retention
  on_escalation: block        # block | flag

# ── Input scanning ────────────────────────────────────────────────────────
scan_input:
  enabled: true
  block_at: high
  scanners:
    - name: injection_scan       # data-boundary attacks: tool coercion, exfiltration, context spoofing
    - name: jailbreak_scan       # guardrail-integrity attacks: persona override, instruction override, etc.
    - name: identity_spoof_scan  # agentic identity spoofing: claimed orchestrator/system authority
    - name: regex_pii
    - name: injection_scan

# ── File upload scanning ──────────────────────────────────────────────────
# FileScanner handles MIME, size, PDF JS, EXIF, ZIP, Office macros, and
# runs InjectionScanner on extracted text automatically.
scan_file:
  enabled: false
  block_at: high
  max_size_mb: 50

# ── Tool result scanning (indirect injection) — T6 ───────────────────────
scan_tool_result:
  enabled: false
  block_at: high

# ── Tool call gate ────────────────────────────────────────────────────────
check_tool_call:
  rate_limit:
    enabled: false
    window_seconds: 60
    max_calls_per_window: 60
    max_calls_per_tool: 20
  arg_scanners:
    - name: regex_pii
  scan_args_for_tags:
    - sensitive

# ── Output scanning ───────────────────────────────────────────────────────
scan_output:
  enabled: true
  block_at: high
  scanners:
    - name: regex_pii

# ── Policy ────────────────────────────────────────────────────────────────
policy:
  name: rules
  config:
    rules_path: ./policies/rules.yaml

# ── Audit sinks ───────────────────────────────────────────────────────────
# Optional — defaults to stdout when not specified.
# Available: stdout, file
audit_sinks:
  - name: stdout
  # - name: file
  #   config:
  #     path: ./logs/audit.jsonl

# ── Audit signing — T8 ───────────────────────────────────────────────────
# HMAC-SHA256 signs every audit event. secret:// resolved from env var.
audit_signing:
  enabled: false
  secret: "secret://AUDIT_SIGNING_KEY"

# ── Tool sources ──────────────────────────────────────────────────────────
# Sources declare where tools come from. MCP sources connect to external
# servers; local sources expose already-registered tools to agents by name.
# Credentials are resolved via SecretsProvider (secret:// URIs).
#
# sources:
#   # Option A — use a pre-built connector manifest (recommended)
#   - name: slack
#     connector: slack          # loads manifest: url, allowed_urls, tags, tool specs
#     credentials:
#       token: "secret://SLACK_BOT_TOKEN"
#
#   - name: github
#     connector: github
#     credentials:
#       token: "secret://GITHUB_TOKEN"
#
#   - name: notion
#     connector: notion
#     credentials:
#       token: "secret://NOTION_TOKEN"
#
#   # Option B — manual configuration (full control)
#   - name: slack_mcp
#     transport: mcp
#     url: "https://mcp.slack.com/sse"
#     credentials:
#       token: "secret://SLACK_MCP_TOKEN"
#     tags:
#       - external_mcp
#       - messaging
#     required: true   # default — failed connection raises ConfigError at startup
#
#   - name: analytics_mcp
#     transport: mcp
#     url: "https://analytics.internal/sse"
#     required: false  # optional — failure is logged and skipped, not fatal
#
#   - name: docs_local
#     transport: local
#     tags:
#       - read
#       - internal
#     required: true

